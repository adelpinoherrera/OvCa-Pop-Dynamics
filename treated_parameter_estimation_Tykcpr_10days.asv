    plot(Tykcpr_10t_days, S_fit_mean, 'g-', 'LineWidth', 3);
    
    title(sprintf('Ce = %.2f μM', ce_all(i)));
    xlabel('Time (days)'); ylabel('Sensitive cells');
    ylim([0 600000]); grid on;
    legend('Replicates', 'Model fit', 'Location', 'best');
end
sgtitle(sprintf('Model (a=%.2f):\n', malphat_hat(1)));

saveas(gcf, fullfile(outdir,'Tykcpr_treated_alphaonly_multdruglinear_alphaT0_constD_10days_Model21.png'));

writematrix([Tykcpr_10t_days, model_fit_all{1}], fullfile(outdir,'Tykcpr_IC50treated_alphaonly_multdruglinear_alphaT0_constD_10days_Model21.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{2}], fullfile(outdir,'Tykcpr_IC25treated_alphaonly_multdruglinear_alphaT0_constD_10days_Model21.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{3}], fullfile(outdir,'Tykcpr_IC75treated_alphaonly_multdruglinear_alphaT0_constD_10days_Model21.csv'));
