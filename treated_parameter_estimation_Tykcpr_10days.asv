%Try different treatment models for Tykcpr for 10 days, the other cell lines
%are in other scripts 
%of data 
clear all;

outdir = '/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results/Tykcpr_treated_10days';

%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%Starts with Tykcpr treated
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%Import all data
Tykcpr_IC50_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC50_0.66um_40k_cellsinwell.csv');
Tykcpr_IC25_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC75_0.12um_40k_cellsinwell.csv');
Tykcpr_IC75_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC25_0.85um_40k_cellsinwell.csv');

Tykcpr_t_days = Tykcpr_IC50_data.Day; %no need to define multiple times, time is all the same for all concentrations
Tykcpr_IC50_y_raw = [Tykcpr_IC50_data.Rep1, Tykcpr_IC50_data.Rep2, Tykcpr_IC50_data.Rep3];
Tykcpr_IC25_y_raw = [Tykcpr_IC25_data.Rep1, Tykcpr_IC25_data.Rep2, Tykcpr_IC25_data.Rep3];
Tykcpr_IC75_y_raw = [Tykcpr_IC75_data.Rep1, Tykcpr_IC75_data.Rep2, Tykcpr_IC75_data.Rep3];

Tykcpr_10t_days = Tykcpr_t_days(1:11);
Tykcpr_IC25_10y_raw = Tykcpr_IC25_y_raw(1:11,:); %rows from 1-9 and all columns
Tykcpr_IC50_10y_raw = Tykcpr_IC50_y_raw(1:11,:);
Tykcpr_IC75_10y_raw = Tykcpr_IC75_y_raw(1:11,:);

%Define extracellular concentration (uM) values for each condition 
ce_IC50 = 0.66; 
ce_IC25 = 0.12;
ce_IC75 = 0.85;

%Define logistic growth constants 
rS = 0.5339; %growth rate (day^-1)
KS = 421668.8619;  %carrying capacity (cells)

%Define drug parameters 
IC50S = 4.210567; %the IC50 for sensitive cells, after 72hr exposure

%MODEL 1 (Equation 3)
%%%Estimate for n and alpha - Tykcpr (constant D) multiplicative drug kill term
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%Estimate for parameters
p0 = [2; 0.5];      % [n; alpha]
lb = [0.01; 0.01];   % reasonable bounds
ub = [10; 20.0];

res_fun_nandalpha_constD = @(p) all_datasets_residual_reps_n_and_alpha_constD_2params(p, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

%run globalsearch with 200 starts
problem_nandalpha_constD = createOptimProblem(...
    'lsqnonlin', ... %can't use lsqcurvefit because it expects x and y arguments
    'x0', p0, ...
    'objective', res_fun_nandalpha_constD, ...
    'lb', lb, ...
    'ub', ub);

ms_nandalpha_constD = MultiStart('UseParallel', true, 'Display', 'iter', 'StartPointsToRun','bounds-ineqs');  % Set true if desired
nStarts = 200; %more start to ensure reproducibility 
[d_hat, resnorm_d] = run(ms_nandalpha_constD, problem_nandalpha_constD, nStarts);
fprintf('Fitted n and alpha - mult - constD Tykcpr (10 days)\n')
fprintf('Fitted Hill coefficient n = %.4f\n', d_hat(1));
fprintf('Fitted alpha term a = %.4f\n', d_hat(2));
fprintf('Sum of squared residuals = %.2f\n', resnorm_d);
% All 200 local solver runs converged with a positive local solver exitflag.
% Fitted n and alpha - mult - constD Tykcpr (10 days)
% Fitted Hill coefficient n = 3.2359
% Fitted alpha term a = 2.0000
% Sum of squared residuals = 335808573208.74

% Run lsqnonlin separately to get Jacobian using MultiStart solution as initial guess
[p_final, resnorm_final, residual_final, exitflag, output_final, lambda_final, J] = ...
lsqnonlin(res_fun_nandalpha_constD, d_hat, lb, ub);

% Compute 95% confidence intervals
ci = nlparci(p_final, residual_final, 'jacobian', J);

% Print confidence intervals
fprintf('95 Confidence Intervals:\n')
fprintf('n: [%.4f, %.4f]\n', ci(1,1), ci(1,2));
fprintf('a: [%.4f, %.4f]\n', ci(2,1), ci(2,2));
% Local minimum possible.
% lsqnonlin stopped because the final change in the sum of squares relative to 
% its initial value is less than the value of the function tolerance.
% <stopping criteria details>
% 95 Confidence Intervals:
% n: [-44.9961, 51.4678]
% a: [-155.7219, 159.7219]

[~, BIC_IC50, BIC_IC25, BIC_IC75] = all_datasets_residual_reps_n_and_alpha_constD_2params(d_hat, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

fprintf('Model (n=%.2f, a=%.2f):\n', d_hat(1), d_hat(2));
fprintf('  BIC IC50  = %.2f\n', BIC_IC50);
fprintf('  BIC IC25  = %.2f\n', BIC_IC25);
fprintf('  BIC IC75  = %.2f\n', BIC_IC75);
fprintf('  BIC total = %.2f\n', BIC_IC50 + BIC_IC25 + BIC_IC75);
% Model (n=3.24, a=2.00):
%   BIC IC50  = 737.71
%   BIC IC25  = 741.57
%   BIC IC75  = 701.74
%   BIC total = 2181.03

%Put datasets together 
ce_all = [ce_IC50, ce_IC25, ce_IC75];
S_raw_all = {Tykcpr_IC50_10y_raw, Tykcpr_IC25_10y_raw, Tykcpr_IC75_10y_raw};

figure; 
for i = 1:3
    subplot(1,3,i); hold on;
    
    % All 3 replicates (gray circles)
    S_raw = S_raw_all{i};
    [nTimes, nReps] = size(S_raw);
    plot(Tykcpr_10t_days, S_raw, 'ko', 'MarkerFaceColor', [0.8 0.8 0.8], 'MarkerSize', 6);
    
    % Fitted mean curve (red line)
    S_fit_all = zeros(nTimes, nReps);
    for j = 1:nReps
        S0 = S_raw(1,j);
        S_fit_all(:,j) = simulate_treat_for_dataset_withConstantD(d_hat(1), d_hat(2), Tykcpr_10t_days, S0, ...
            ce_all(i), rS, KS, IC50S);
    end
    S_fit_mean = mean(S_fit_all, 2);
    plot(Tykcpr_10t_days, S_fit_mean, 'g-', 'LineWidth', 3);
    
    title(sprintf('Ce = %.2f μM', ce_all(i)));
    xlabel('Time (days)'); ylabel('Sensitive cells');
    ylim([0 600000]); grid on;
    legend('Replicates', 'Model fit', 'Location', 'best');
end
sgtitle(sprintf('Model (n=%.2f, a=%.2f):\n', d_hat(1), d_hat(2)));

saveas(gcf, fullfile(outdir,'Tykcpr_treated_nandalpha_mult_constD_10days_model1.png'));

writematrix(S_raw_all{1,1}, fullfile(outdir, 'Tykcpr_IC50treated_nandalpha_mult_constD_10days_model1.csv'));
writematrix(S_raw_all{1,2}, fullfile(outdir, 'Tykcpr_IC25treated_nandalpha_mult_constD_10days_model1.csv'));
writematrix(S_raw_all{1,3}, fullfile(outdir, 'Tykcpr_IC75treated_nandalpha_mult_constD_10days_model1.csv'));

%MODEL 2 (Equation 4)
%%%Estimate for n and alpha - Tykcpr (constant D) additive drug kill term
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
clear all;

outdir = '/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results/Tykcpr_treated_10days';

%Import all data
Tykcpr_IC50_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC50_0.66um_40k_cellsinwell.csv');
Tykcpr_IC25_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC75_0.12um_40k_cellsinwell.csv');
Tykcpr_IC75_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC25_0.85um_40k_cellsinwell.csv');

Tykcpr_t_days = Tykcpr_IC50_data.Day; %no need to define multiple times, time is all the same for all concentrations
Tykcpr_IC50_y_raw = [Tykcpr_IC50_data.Rep1, Tykcpr_IC50_data.Rep2, Tykcpr_IC50_data.Rep3];
Tykcpr_IC25_y_raw = [Tykcpr_IC25_data.Rep1, Tykcpr_IC25_data.Rep2, Tykcpr_IC25_data.Rep3];
Tykcpr_IC75_y_raw = [Tykcpr_IC75_data.Rep1, Tykcpr_IC75_data.Rep2, Tykcpr_IC75_data.Rep3];

%downsample data
Tykcpr_10t_days = Tykcpr_t_days(1:11);
Tykcpr_IC25_10y_raw = Tykcpr_IC25_y_raw(1:11,:); %rows from 1-9 and all columns
Tykcpr_IC50_10y_raw = Tykcpr_IC50_y_raw(1:11,:);
Tykcpr_IC75_10y_raw = Tykcpr_IC75_y_raw(1:11,:);

%Define extracellular concentration (uM) values for each condition 
ce_IC50 = 0.66; 
ce_IC25 = 0.12;
ce_IC75 = 0.85;

%Define logistic growth constants 
rS = 0.5339; %growth rate (day^-1)
KS = 421668.8619;  %carrying capacity (cells)

%Define drug parameters 
IC50S = 4.210567; %the IC50 for sensitive cells, after 72hr exposure

%Estimate for parameters
p0 = [2; 0.5];      % [n; alpha]
lb = [0.01; 0.01];   % reasonable bounds
ub = [10; 2.0];

res_fun_nandalpha_constD_add = @(p) all_datasets_residual_reps_n_and_alpha_constD_add(p, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

%run globalsearch with 200 starts
problem_nandalpha_constD_add = createOptimProblem(...
    'lsqnonlin', ... %can't use lsqcurvefit because it expects x and y arguments
    'x0', p0, ...
    'objective', res_fun_nandalpha_constD_add, ...
    'lb', lb, ...
    'ub', ub);

ms_nandalpha_constD_add = MultiStart('UseParallel', true, 'Display', 'iter', 'StartPointsToRun','bounds-ineqs');  % Set true if desired
nStarts = 200; %more start to ensure reproducibility 
[a_hat, resnorm_a] = run(ms_nandalpha_constD_add, problem_nandalpha_constD_add, nStarts);
fprintf('Fitted n and alpha - add - constD Tykcpr (10 days)\n')
fprintf('Fitted Hill coefficient n = %.4f\n', a_hat(1));
fprintf('Fitted alpha term a = %.4f\n', a_hat(2));
fprintf('Sum of squared residuals = %.2f\n', resnorm_a);
% All 200 local solver runs converged with a positive local solver exitflag.
% Fitted n and alpha - add - constD Tykcpr (10 days)
% Fitted Hill coefficient n = 3.3658
% Fitted alpha term a = 2.0000
% Sum of squared residuals = 334679139047.96

% Run lsqnonlin separately to get Jacobian using MultiStart solution as initial guess
[p_final, resnorm_final, residual_final, exitflag, output_final, lambda_final, J] = ...
lsqnonlin(res_fun_nandalpha_constD_add, a_hat, lb, ub);

% Compute 95% confidence intervals
ci = nlparci(p_final, residual_final, 'jacobian', J);

% Print confidence intervals
fprintf('95 Confidence Intervals:\n')
fprintf('n: [%.4f, %.4f]\n', ci(1,1), ci(1,2));
fprintf('a: [%.4f, %.4f]\n', ci(2,1), ci(2,2));
% Local minimum possible.
% lsqnonlin stopped because the final change in the sum of squares relative to 
% its initial value is less than the value of the function tolerance.
% <stopping criteria details>
% 95 Confidence Intervals:
% n: [-28.3727, 35.1042]
% a: [-101.7890, 105.7890]

[~, BIC_IC50, BIC_IC25, BIC_IC75] = all_datasets_residual_reps_n_and_alpha_constD_add(a_hat, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

fprintf('Model (n=%.2f, a=%.2f):\n', a_hat(1), a_hat(2));
fprintf('  BIC IC50  = %.2f\n', BIC_IC50);
fprintf('  BIC IC25  = %.2f\n', BIC_IC25);
fprintf('  BIC IC75  = %.2f\n', BIC_IC75);
fprintf('  BIC total = %.2f\n', BIC_IC50 + BIC_IC25 + BIC_IC75);
% Model (n=3.37, a=2.00):
%   BIC IC50  = 737.91
%   BIC IC25  = 741.58
%   BIC IC75  = 700.31
%   BIC total = 2179.79

%Put datasets together 
ce_all = [ce_IC50, ce_IC25, ce_IC75];
S_raw_all = {Tykcpr_IC50_10y_raw, Tykcpr_IC25_10y_raw, Tykcpr_IC75_10y_raw};

model_fit_all = cell(1,3);

figure; 
for i = 1:3
    subplot(1,3,i); hold on;
    
    % All 3 replicates (gray circles)
    S_raw = S_raw_all{i};
    [nTimes, nReps] = size(S_raw);
    plot(Tykcpr_10t_days, S_raw, 'ko', 'MarkerFaceColor', [0.8 0.8 0.8], 'MarkerSize', 6);
    
    % Fitted mean curve (red line)
    S_fit_all = zeros(nTimes, nReps);
    for j = 1:nReps
        S0 = S_raw(1,j);
        S_fit_all(:,j) = simulate_treat_for_dataset_withConstantD_add(a_hat(1),a_hat(2), Tykcpr_10t_days, S0, ...
            ce_all(i), rS, KS, IC50S);
    end
    S_fit_mean = mean(S_fit_all, 2);
    model_fit_all{i} = S_fit_mean;
    plot(Tykcpr_10t_days, S_fit_mean, 'g-', 'LineWidth', 3);
    
    title(sprintf('Ce = %.2f μM', ce_all(i)));
    xlabel('Time (days)'); ylabel('Sensitive cells');
    ylim([0 600000]); grid on;
    legend('Replicates', 'Model fit', 'Location', 'best');
end
sgtitle(sprintf('Model (n=%.2f, a=%.2f):\n', a_hat(1), a_hat(2)));

saveas(gcf, fullfile(outdir,'Tykcpr_treated_nandalpha_add_constD_10days_model2.png'));

writematrix([Tykcpr_10t_days, model_fit_all{1}], fullfile(outdir,'Tykcpr_IC50treated_nandalpha_add_constD_10days_model2.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{2}], fullfile(outdir,'Tykcpr_IC25treated_nandalpha_add_constD_10days_model2.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{3}], fullfile(outdir,'Tykcpr_IC75treated_nandalpha_add_constD_10days_model2.csv'));

