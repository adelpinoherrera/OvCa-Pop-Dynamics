% writematrix(S_raw_all{1,2}, fullfile(outdir, 'Tykcpr_IC25treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.csv'));
% writematrix(S_raw_all{1,3}, fullfile(outdir, 'Tykcpr_IC75treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.csv'));

