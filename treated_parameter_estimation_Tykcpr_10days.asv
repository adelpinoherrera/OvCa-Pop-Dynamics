%average of the 3 R2 squared average: mean([0.8311,0.8211,0.9145]) = 0.8556


%MODEL 15 (Equation 
%%%Estimate for alpha only - Tykcpr (constant D) multiplicative hill term,
%%%alpha is time dependent, drug kill is 0 at time 0
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
clear all;

outdir = '/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results';

%Import all data
Tykcpr_IC50_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC50_0.66um_40k_cellsinwell.csv');
Tykcpr_IC25_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC75_0.12um_40k_cellsinwell.csv');
Tykcpr_IC75_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC25_0.85um_40k_cellsinwell.csv');

Tykcpr_t_days = Tykcpr_IC50_data.Day; %no need to define multiple times, time is all the same for all concentrations
Tykcpr_IC50_y_raw = [Tykcpr_IC50_data.Rep1, Tykcpr_IC50_data.Rep2, Tykcpr_IC50_data.Rep3];
Tykcpr_IC25_y_raw = [Tykcpr_IC25_data.Rep1, Tykcpr_IC25_data.Rep2, Tykcpr_IC25_data.Rep3];
Tykcpr_IC75_y_raw = [Tykcpr_IC75_data.Rep1, Tykcpr_IC75_data.Rep2, Tykcpr_IC75_data.Rep3];

%downsample data
Tykcpr_10t_days = Tykcpr_t_days(1:11);
Tykcpr_IC25_10y_raw = Tykcpr_IC25_y_raw(1:11,:); %rows from 1-9 and all columns
Tykcpr_IC50_10y_raw = Tykcpr_IC50_y_raw(1:11,:);
Tykcpr_IC75_10y_raw = Tykcpr_IC75_y_raw(1:11,:);

%Define extracellular concentration (uM) values for each condition 
ce_IC50 = 0.66; 
ce_IC25 = 0.12;
ce_IC75 = 0.85;

%Define logistic growth constants 
rS = 0.5339; %growth rate (day^-1)
KS = 421668.8619;  %carrying capacity (cells)

%Define drug parameters 
IC50S = 4.210567; %the IC50 for sensitive cells, after 72hr exposure

%Estimate for parameters
p0 = [0.5];      % [alpha]
lb = [0.0001];   % reasonable bounds
ub = [20];

res_fun_nandalpha_constD_mult_alphaonly_t0 = @(p) all_datasets_residual_reps_n_and_alpha_constD_mult_alphaonly_t0(p, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

%run globalsearch with 200 starts
problem_nandalpha_constD_mult_alphaonly_t0 = createOptimProblem(...
    'lsqnonlin', ... %can't use lsqcurvefit because it expects x and y arguments
    'x0', p0, ...
    'objective', res_fun_nandalpha_constD_mult_alphaonly_t0, ...
    'lb', lb, ...
    'ub', ub);

ms_nandalpha_constD_mult_alphaonly_t0 = MultiStart('UseParallel', true, 'Display', 'iter', 'StartPointsToRun','bounds-ineqs');  % Set true if desired
nStarts = 200; %more start to ensure reproducibility 
[malphat_hat, resnorm_malphat] = run(ms_nandalpha_constD_mult_alphaonly_t0, problem_nandalpha_constD_mult_alphaonly_t0, nStarts);
fprintf('Fitted alpha only - mult drug - alpha T t0=0 - constD Tykcpr (10 days)\n')
fprintf('Fitted alpha term a = %.4f\n', malphat_hat(1));
fprintf('Sum of squared residuals = %.2f\n', resnorm_malphat);
% All 200 local solver runs converged with a positive local solver exitflag.
% Fitted alpha only - mult drug - alpha T t0=0 - constD Tykcpr (10 days)
% Fitted alpha term a = 0.0001
% Sum of squared residuals = 337010019035.75

% Run lsqnonlin separately to get Jacobian using MultiStart solution as initial guess
[p_final, resnorm_final, residual_final, exitflag, output_final, lambda_final, J] = ...
lsqnonlin(res_fun_nandalpha_constD_mult_alphaonly_t0, malphat_hat, lb, ub);

% Compute 95% confidence intervals
ci = nlparci(p_final, residual_final, 'jacobian', J);

% Print confidence intervals
fprintf('95 Confidence Intervals:\n')
fprintf('a: [%.4f, %.4f]\n', ci(1,1), ci(1,2));
% Local minimum possible.
% lsqnonlin stopped because the final change in the sum of squares relative to 
% its initial value is less than the value of the function tolerance.
% <stopping criteria details>
% 95 Confidence Intervals:
% a: [-0.1717, 0.1719]

[~, BIC_IC50, BIC_IC25, BIC_IC75] = all_datasets_residual_reps_n_and_alpha_constD_mult_alphaonly_t0(malphat_hat, rS, KS, IC50S, ...
                                         Tykcpr_10t_days, Tykcpr_IC50_10y_raw, ce_IC50, ...
                                         Tykcpr_10t_days, Tykcpr_IC25_10y_raw, ce_IC25, ...
                                         Tykcpr_10t_days, Tykcpr_IC75_10y_raw, ce_IC75);

fprintf('Model (a=%.2f):\n', malphat_hat(1));
fprintf('  BIC IC50  = %.2f\n', BIC_IC50);
fprintf('  BIC IC25  = %.2f\n', BIC_IC25);
fprintf('  BIC IC75  = %.2f\n', BIC_IC75);
fprintf('  BIC total = %.2f\n', BIC_IC50 + BIC_IC25 + BIC_IC75);
% Model (a=0.00):
%   BIC IC50  = 733.43
%   BIC IC25  = 738.08
%   BIC IC75  = 701.29
%   BIC total = 2172.79

%Put datasets together 
ce_all = [ce_IC50, ce_IC25, ce_IC75];
S_raw_all = {Tykcpr_IC50_10y_raw, Tykcpr_IC25_10y_raw, Tykcpr_IC75_10y_raw};
model_fit_all = cell(1,3);

figure; 
for i = 1:3
    subplot(1,3,i); hold on;
    
    % All 3 replicates (gray circles)
    S_raw = S_raw_all{i};
    [nTimes, nReps] = size(S_raw);
    plot(Tykcpr_10t_days, S_raw, 'ko', 'MarkerFaceColor', [0.8 0.8 0.8], 'MarkerSize', 6);
    
    % Fitted mean curve (red line)
    S_fit_all = zeros(nTimes, nReps);
    for j = 1:nReps
        S0 = S_raw(1,j);
        S_fit_all(:,j) = simulate_treat_for_dataset_withConstD_mult_alphaonly_t0(malphat_hat(1), Tykcpr_10t_days, S0, ...
            ce_all(i), rS, KS, IC50S);
    end
    S_fit_mean = mean(S_fit_all, 2);
    plot(Tykcpr_10t_days, S_fit_mean, 'g-', 'LineWidth', 3);
    
    title(sprintf('Ce = %.2f μM', ce_all(i)));
    xlabel('Time (days)'); ylabel('Sensitive cells');
    ylim([0 600000]); grid on;
    legend('Replicates', 'Model fit', 'Location', 'best');
end
sgtitle(sprintf('Model (a=%.2f):\n', malphat_hat(1)));

saveas(gcf, fullfile(outdir,'Tykcpr_treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.png'));

writematrix([Tykcpr_10t_days, model_fit_all{1}], fullfile(outdir,'Tykcpr_IC50treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{2}], fullfile(outdir,'Tykcpr_IC25treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.csv'));
writematrix([Tykcpr_10t_days, model_fit_all{3}], fullfile(outdir,'Tykcpr_IC75treated_alphaonly_multdrug_alphaT0_constD_10days_Model15.csv'));

