% writematrix(S_raw_all{1,2}, fullfile(outdir, 'Tykcpr_IC25treated_alphaonly_adddrug_alphaT0_constD_10days_Model14.csv'));
% writematrix(S_raw_all{1,3}, fullfile(outdir, 'Tykcpr_IC75treated_alphaonly_adddrug_alphaT0_constD_10days_Model14.csv'));

%R squared calculation
clear all;
Tykcpr_IC50_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC50_0.66um_40k_cellsinwell.csv');
Tykcpr_IC25_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC75_0.12um_40k_cellsinwell.csv');
Tykcpr_IC75_data = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/data/Tykcpr_IC25_0.85um_40k_cellsinwell.csv');

Tykcpr_t_days = Tykcpr_IC50_data.Day; %no need to define multiple times, time is all the same for all concentrations
Tykcpr_IC50_y_raw = [Tykcpr_IC50_data.Rep1, Tykcpr_IC50_data.Rep2, Tykcpr_IC50_data.Rep3];
Tykcpr_IC25_y_raw = [Tykcpr_IC25_data.Rep1, Tykcpr_IC25_data.Rep2, Tykcpr_IC25_data.Rep3];
Tykcpr_IC75_y_raw = [Tykcpr_IC75_data.Rep1, Tykcpr_IC75_data.Rep2, Tykcpr_IC75_data.Rep3];

Tykcpr_IC25_10y_raw = Tykcpr_IC25_y_raw(1:11,:); %rows from 1-9 and all columns
Tykcpr_IC50_10y_raw = Tykcpr_IC50_y_raw(1:11,:);
Tykcpr_IC75_10y_raw = Tykcpr_IC75_y_raw(1:11,:);

Tykcpr_IC25_10y_all = Tykcpr_IC25_10y_raw(:);
Tykcpr_IC50_10y_all = Tykcpr_IC50_10y_raw(:);
Tykcpr_IC75_10y_all = Tykcpr_IC75_10y_raw(:);

%IC25
Tykcpr_IC25_predicted = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results/Tykcpr_treated_10days/Tykcpr_IC25treated_alphaonly_adddrug_alphaT0_constD_10days_Model14.csv');
Tykcpr_IC25_predicted = table2array(Tykcpr_IC25_predicted(:,2)); %only the second column 
Tykcpr_IC25_predicted = repmat(Tykcpr_IC25_predicted,3,1); %repeat 3 times 

SS_res_IC25 = sum((Tykcpr_IC25_10y_all - Tykcpr_IC25_predicted).^2);
SS_tot_IC25 = sum((Tykcpr_IC25_10y_all - mean(Tykcpr_IC25_10y_all)).^2);
R2_IC25 = 1 - SS_res_IC25 / SS_tot_IC25;

fprintf('R-squared for IC25: %.4f\n', R2_IC25);
%R-squared for IC25: 0.8311

%IC50
Tykcpr_IC50_predicted = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results/Tykcpr_treated_10days/Tykcpr_IC50treated_alphaonly_adddrug_alphaT0_constD_10days_Model14.csv');
Tykcpr_IC50_predicted = table2array(Tykcpr_IC50_predicted(:,2)); %only the second column 
Tykcpr_IC50_predicted = repmat(Tykcpr_IC50_predicted,3,1); %repeat 3 times 

SS_res_IC50 = sum((Tykcpr_IC50_10y_all - Tykcpr_IC50_predicted).^2);
SS_tot_IC50 = sum((Tykcpr_IC50_10y_all - mean(Tykcpr_IC50_10y_all)).^2);
R2_IC50 = 1 - SS_res_IC50 / SS_tot_IC50;

fprintf('R-squared for IC50: %.4f\n', R2_IC50);
%R-squared for IC50: 0.8211

%IC75
Tykcpr_IC75_predicted = readtable('/blue/ferrallm/01_analysis/adelpinoherrera_OvCa-Aim2-MathModelingMATLAB/Tyk/clean_parameterization/results/Tykcpr_treated_10days/Tykcpr_IC75treated_alphaonly_adddrug_alphaT0_constD_10days_Model14.csv');
Tykcpr_IC75_predicted = table2array(Tykcpr_IC75_predicted(:,2)); %only the second column 
Tykcpr_IC75_predicted = repmat(Tykcpr_IC75_predicted,3,1); %repeat 3 times 

